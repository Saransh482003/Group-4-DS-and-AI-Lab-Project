# Paths relative to app/ directory
YOLO_WEIGHTS_REL=../model_training/object_detection/best-weights/YOLO11s-Final-Training.pt
DEPTH_MODEL_DIR_REL=../model_training/depth_estimation/model_weights/depth_anything_v2_metric_hypersim_vits.pth
PIPER_EXE_REL=../piper/piper.exe
PIPER_VOICE_MODEL_REL=../piper/piper_voices/en_US-amy-medium.onnx
PIPER_VOICE_CONFIG_REL=../piper/piper_voices/en_US-amy-medium.onnx.json

# I/O
OUTPUT_JSON_REL=bbox_output.json
OUTPUT_VIDEO_REL=yolo_depth_output.mp4
VIDEO_SOURCE=1
SHOW_WINDOWS=1
NEW_SHOW_WINDOWS=1
NEW_PLOT_STREAM_MODE=1

# Pipeline mode
PLOT_STREAM_MODE=0
NAV_LOGIC_MODE=0

# Runtime and profiling
INFERENCE_DURATION_MINUTES=10
NEW_INFERENCE_DURATION_MINUTES=0
NEW_SHOW_SIDE_BY_SIDE_STREAMS=0
NEW_ZONE_UNPASSABLE_COVERAGE_THRESHOLD=0.40
WARMUP_FRAMES=15
RESOURCE_SAMPLE_EVERY_N_FRAMES=10
DISABLE_DISPLAY_FOR_BENCHMARK=0
GPU_TIMING_STRICT_SYNC=0
ZONE_SHADE_OPACITY=0.1

# TTS
TTS_ENABLED=1
ENABLE_ASYNC_TTS=1
TTS_QUEUE_MAXSIZE=5
TTS_PLAY_AUDIO=0
TTS_DIRECT_PLAYBACK=1
TTS_SPEAK_ONCE_PER_EXECUTION=0
TTS_SPEAK_ON_COMMAND_CHANGE=1
TTS_MIN_INTERVAL_SECONDS=1.2

# Deployment
HF_TOKEN=your_hugging_face_token_here_if_deploying
